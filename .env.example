# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit real keys.
#
# Local setup:
#   cp .env.example .env.local
#   # edit .env.local, then restart: npm run dev
#
# Vercel (production):
#   Project → Settings → Environment Variables
#   Add the same names below for Production (and Preview if you want).
#
# --- OpenAI (recommended) -----------------------------------------------
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: force mock responses (no API calls). Useful before billing is set up.
# SKINLOG_AI_MOCK=true

# Optional: override the vision model (default: gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: Realtime voice model + default voice (legacy OpenAI realtime)
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=alloy

# ElevenLabs — /modules virtual patient simulator
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# ConvAI agent ID from https://elevenlabs.io/app/conversational-ai (starts with agent_)
# SkinTools agent example:
ELEVENLABS_AGENT_ID=agent_3401kv4c6fgyew1bp5gvnxhdq7bz
# Voice for sessions — defaults to your SkinTools agent voice if unset
ELEVENLABS_VOICE_ID=cjVigY5qzO86Huf0OWal
#
# Required in ElevenLabs agent → Security → Overrides:
#   • System prompt (prompt) — ON  ← needed for persona/scenario per session
#   • First message — ON
#   • Voice — ON
# Alternative if prompt override stays off: set agent system prompt to
#   {{patient_instructions}}
# and add patient_instructions as a dynamic variable placeholder in the agent.
