# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit real keys.
#
# Local setup:
#   cp .env.example .env.local
#   # edit .env.local, then restart: npm run dev
#
# Vercel (production):
#   Project → Settings → Environment Variables
#   Add the same names below for Production (and Preview if you want).
#
# --- OpenAI (recommended) -----------------------------------------------
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: force mock responses (no API calls). Useful before billing is set up.
# SKINLOG_AI_MOCK=true

# Optional: override the vision model (default: gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: Realtime voice model + default voice (legacy OpenAI realtime)
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=alloy

# ElevenLabs — /modules virtual patient simulator
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Conversational AI agent ID (NOT a voice ID) from https://elevenlabs.io/app/conversational-ai
# Copy the agent ID from your agent's settings. If wrong/missing, the first agent in your account is used.
# Enable "Allow overrides" for: prompt, first_message, voice_id
ELEVENLABS_AGENT_ID=
# Voice used for all virtual patient sessions (from ElevenLabs Voice Library)
ELEVENLABS_VOICE_ID=
